# Supabase Database (Project Settings → Database → Connection string)
DATABASE_URL=             # Transaction pooler (포트 6543), 앱 런타임용
DIRECT_URL=               # Direct/Session (포트 5432), 마이그레이션용

# Supabase Storage/API (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI API (사진 판정용 vision 모델 호출)
OPENAI_API_KEY=
OPENAI_VISION_MODEL="gpt-4o-mini"

# Kakao Maps JavaScript SDK 키 (브라우저 노출용, NEXT_PUBLIC_ 접두사 필수)
NEXT_PUBLIC_KAKAO_JS_KEY=

# 관리자 화면 접근용 비밀 URL 경로 슬러그 (로그인 없음, /admin/{슬러그}로만 접근)
ADMIN_SECRET_PATH=
