# 로컬 개발용: 그대로 두면 SQLite 사용. Supabase 연동 시 postgres 연결 문자열로 교체.
DATABASE_URL="file:./dev.db"

# OpenAI API (사진 판정용 vision 모델 호출)
OPENAI_API_KEY=
OPENAI_VISION_MODEL="gpt-4o-mini"

# Kakao Maps JavaScript SDK 키 (브라우저 노출용, NEXT_PUBLIC_ 접두사 필수)
NEXT_PUBLIC_KAKAO_JS_KEY=

# 관리자 화면 접근용 비밀 URL 경로 슬러그 (로그인 없음, /admin/{슬러그}로만 접근)
ADMIN_SECRET_PATH=
